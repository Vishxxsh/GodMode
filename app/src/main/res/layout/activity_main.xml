<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#000000">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="UNIVERSAL REMAPPER: FINAL BUILD"
        android:textColor="#FF0000"
        android:textStyle="bold"
        android:gravity="center" />

    <Button
        android:id="@+id/btnRecord"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="START RECORDING TRIGGER"
        android:layout_marginTop="10dp" />

    <TextView
        android:id="@+id/tvSavedTrigger"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Saved Trigger: NONE"
        android:textColor="#00FF00"
        android:padding="10dp" />

    <EditText
        android:id="@+id/etAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Package Name (e.g. com.brave.browser)"
        android:textColor="#FFFFFF"
        android:background="#333333"
        android:padding="10dp"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/tvLiveLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Live System Feed..."
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:scrollbars="vertical"
        android:layout_marginTop="10dp" />

</LinearLayout>